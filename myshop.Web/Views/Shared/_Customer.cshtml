@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>myShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #eef2f7 0%, #d9e4f5 40%, #c3dafe 100%);
            min-height: 100vh;
            margin: 0;
            padding: 0;
            animation: fadeIn 1s ease-in-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        nav.navbar {
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);
            background: linear-gradient(90deg, #ffffff 0%, #f8fbff 100%) !important;
            padding: 1rem 0 !important;
            animation: slideDown 0.8s ease;
        }

        @@keyframes slideDown {
            from {
                transform: translateY(-40px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.7rem;
            letter-spacing: 0.5px;
        }

        .nav-link-box {
            background: linear-gradient(135deg, #00c6ff 0%, #0072ff 100%);
            color: #fff;
            padding: 0.6rem 1.2rem;
            margin-left: 10px;
            border-radius: 14px;
            box-shadow: 0 4px 14px rgba(0,0,0,0.15);
            transition: 0.3s;
            text-align: center;
            font-weight: 600;
        }

            .nav-link-box:hover {
                background: linear-gradient(135deg, #005bea 0%, #00c6fb 100%);
                transform: translateY(-4px);
                box-shadow: 0 8px 22px rgba(0,0,0,0.25);
            }

            /* Home الحجم الكبير */
            .nav-link-box.home-box {
                padding: 0.9rem 1.8rem;
                font-size: 1.1rem;
            }

        header.hero {
            background: linear-gradient(120deg, #0d6efd 0%, #004bba 50%, #002f7a 100%);
            padding: 7rem 0 8rem;
            border-bottom-left-radius: 40px;
            border-bottom-right-radius: 40px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
            animation: fadeHero 1.2s ease-in-out;
        }

        @@keyframes fadeHero {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        main {
            padding: 3rem 0;
            animation: fadeIn 1.5s ease-in-out;
        }

        footer {
            background: linear-gradient(90deg, #0b0b0b, #1a1a1a);
            border-top-left-radius: 30px;
            border-top-right-radius: 30px;
            padding: 2.5rem 0;
            color: #fff;
            text-align: center;
        }

        .cart-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0.7rem 1.4rem;
            border-radius: 14px;
        }
    </style>
</head>
<body>
    @{
        int cartCount = 0;
        // if (User.Identity.IsAuthenticated)
        // {
        //     var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        //     if (!string.IsNullOrEmpty(userId))
        //     {
        //         cartCount = _unitOfWork.ShoppingCart.GetAll(c => c.ApplicationUserId == userId).Count();
        //     }
        // }
    }

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand text-primary" href="/Customer/Home/Index">myShop</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link-box home-box nav-link active" href="/Customer/Home/Index">Home</a>
                    </li>

                @*     @if (User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole(SD.AdminRole))
                        {
                            <li class="nav-item">
                                <!-- تم إضافة home-box هنا -->
                                <a class="nav-link-box home-box nav-link" href="/Admin/Dashboard/Index">Dashboard</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link-box nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown">My Setting</a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <li><a class="dropdown-item" href="#">my Orders</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" href="/Identity/Account/Manage">Edit Profile</a></li>
                                </ul>
                            </li>
                        }
                    }
                </ul> *@

                <div class="nav-link-box">
                    <partial name="_LoginPartial" />
                </div>

                <a href="/Customer/Cart/Index" class="nav-link-box cart-btn">
                    <i class="bi bi-cart-fill"></i>
                    Cart
                    <span id="cart-count" class="badge bg-dark text-white rounded-pill">@cartCount</span>
                </a>
            </div>
        </div>
    </nav>

    <header class="hero text-white text-center">
        <div class="container">
            <h1 class="display-4">Welcome to myShop</h1>
            <p class="lead text-white-50">Find amazing products with great prices</p>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="py-4">
        <small>&copy; 2025 myShop. All Rights Reserved.</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
